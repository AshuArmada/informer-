# Postgres connection (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://informer:informer@localhost:5432/informer

# Fernet key used to encrypt the GitHub PAT at rest.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# How often (minutes) the trending poller hits the GitHub Search API.
POLL_INTERVAL_MINUTES=10

# SMTP (used to send reports). Example values for Gmail with an app password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional default destination for reports; pre-fills the send form and is used by the schedule.
DEFAULT_REPORT_EMAIL=

# Note: the GitHub PAT itself is NOT set here — it's entered via the in-app
# Settings page and stored encrypted in the database.
